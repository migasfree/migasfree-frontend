{
  "name": "migasfree-frontend",
  "packageManager": "yarn@4.1.0",
  "version": "5.0",
  "type": "module",
  "description": "Systems Management System (frontend) (with Quasar framework)",
  "productName": "Migasfree Frontend",
  "author": "Jose Antonio Chavarría <jachavar@gmail.com>",
  "license": "GPLv3",
  "homepage": "https://github.com/migasfree/migasfree-frontend",
  "repository": {
    "type": "git",
    "url": "https://github.com/migasfree/migasfree-frontend.git"
  },
  "bugs": {
    "url": "https://github.com/migasfree/migasfree-frontend/issues"
  },
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,ts,vue}\"",
    "format": "prettier --write \"**/*.{js,vue,css,html,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check . --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "quasar dev",
    "build": "quasar build",
    "check-bundle-size": "node test/check-bundle-size.js",
    "postinstall": "quasar prepare",
    "prepare": "husky",
    "gettext:extract": "vue-gettext-extract",
    "gettext:translate": "bash scripts/translate.sh",
    "gettext:compile": "vue-gettext-compile",
    "gettext:all": "yarn gettext:extract && yarn gettext:translate && yarn gettext:compile && yarn format",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static"
  },
  "dependencies": {
    "@fontsource/dosis": "5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@novnc/novnc": "1.7.0",
    "@quasar/extras": "1.18.0",
    "@vue-leaflet/vue-leaflet": "0.7.0",
    "@vue/compiler-sfc": "3.5.39",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "ace-builds": "1.44.0",
    "axios": "1.18.1",
    "core-js": "3.49.0",
    "dayjs": "1.11.21",
    "dompurify": "3.4.11",
    "echarts": "6.1.0",
    "leaflet": "1.9.4",
    "pinia": "3.0.4",
    "quasar": "2.20.3",
    "v-code-diff": "1.13.1",
    "vue": "3.5.39",
    "vue-echarts": "8.0.1",
    "vue-good-table-next": "0.2.2",
    "vue-router": "5.1.0",
    "vue3-ace-editor": "2.2.4",
    "vue3-gettext": "4.0.1"
  },
  "devDependencies": {
    "@cypress/vue": "6.0.3",
    "@cypress/webpack-dev-server": "5.6.2",
    "@eslint/js": "10.0.1",
    "@pinia/testing": "1.0.3",
    "@quasar/app-webpack": "4.4.5",
    "@quasar/quasar-app-extension-qmarkdown": "2.0.5",
    "@storybook/addon-a11y": "8.6.18",
    "@storybook/addon-links": "8.6.18",
    "@storybook/vue3": "8.6.18",
    "@storybook/vue3-webpack5": "8.6.18",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/coverage-v8": "4.1.9",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/test-utils": "2.4.11",
    "autoprefixer": "10.5.2",
    "axe-core": "4.12.1",
    "css-loader": "7.1.4",
    "cypress": "15.18.0",
    "cypress-axe": "1.7.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-security": "4.0.1",
    "eslint-plugin-vue": "10.9.2",
    "eslint-plugin-vuejs-accessibility": "2.5.0",
    "eslint-webpack-plugin": "6.0.0",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "postcss": "8.5.16",
    "prettier": "3.9.4",
    "sass": "1.101.0",
    "sass-loader": "16.0.7",
    "storybook": "8.6.18",
    "style-loader": "4.0.0",
    "vite": "8.1.3",
    "vitest": "4.1.9",
    "vitest-axe": "0.1.0",
    "vue-eslint-parser": "10.4.1",
    "webpack": "5.108.3"
  },
  "browserslist": [
    "last 10 Chrome versions",
    "last 10 Firefox versions",
    "last 4 Edge versions",
    "last 7 Safari versions",
    "last 8 Android versions",
    "last 8 ChromeAndroid versions",
    "last 8 FirefoxAndroid versions",
    "last 10 iOS versions",
    "last 5 Opera versions"
  ],
  "engines": {
    "node": ">= 20.19.0",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "resolutions": {
    "braces": ">=3.0.3",
    "micromatch": ">=4.0.8",
    "tmp": ">=0.2.4"
  },
  "lint-staged": {
    "*.{js,vue,ts,cjs,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,html,md,json}": [
      "prettier --write"
    ]
  }
}
